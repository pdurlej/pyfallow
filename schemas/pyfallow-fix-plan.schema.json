{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fallow.tools/schemas/pyfallow-fix-plan.schema.json",
  "title": "pyfallow agent fix plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "tool",
    "version",
    "source_report_schema_version",
    "summary",
    "auto_safe",
    "decision_needed",
    "blocking",
    "limitations"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "tool": { "const": "fallow-py" },
    "version": { "type": "string" },
    "source_report_schema_version": { "type": "string" },
    "diff_scope": { "$ref": "#/$defs/diffScope" },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "auto_safe_count",
        "decision_needed_count",
        "blocking_count",
        "total"
      ],
      "properties": {
        "auto_safe_count": { "type": "integer", "minimum": 0 },
        "decision_needed_count": { "type": "integer", "minimum": 0 },
        "blocking_count": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      }
    },
    "auto_safe": { "type": "array", "items": { "$ref": "#/$defs/item" } },
    "decision_needed": { "type": "array", "items": { "$ref": "#/$defs/item" } },
    "blocking": { "type": "array", "items": { "$ref": "#/$defs/item" } },
    "limitations": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "diffScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "since",
        "since_resolved",
        "changed_files",
        "changed_modules",
        "filtering_active",
        "reason"
      ],
      "properties": {
        "since": { "type": ["string", "null"] },
        "since_resolved": { "type": ["string", "null"] },
        "changed_files": { "type": "array", "items": { "type": "string" } },
        "changed_modules": { "type": "array", "items": { "type": "string" } },
        "filtering_active": { "type": "boolean" },
        "reason": { "type": ["string", "null"] }
      }
    },
    "minimalPatch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "file", "line", "before", "after"],
      "properties": {
        "type": { "enum": ["delete_line", "replace_line"] },
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 1 },
        "before": { "type": "string" },
        "after": { "type": ["string", "null"] }
      }
    },
    "fixOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "description"],
      "properties": {
        "type": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fingerprint",
        "rule",
        "id",
        "file",
        "line",
        "symbol",
        "module",
        "severity",
        "confidence",
        "one_liner",
        "rationale",
        "trade_offs",
        "minimal_patch",
        "investigation_hints",
        "fix_options"
      ],
      "properties": {
        "fingerprint": { "type": "string" },
        "rule": { "type": "string" },
        "id": { "type": "string" },
        "file": { "type": ["string", "null"] },
        "line": { "type": "integer", "minimum": 1 },
        "symbol": { "type": ["string", "null"] },
        "module": { "type": ["string", "null"] },
        "severity": { "enum": ["info", "warning", "error"] },
        "confidence": { "enum": ["low", "medium", "high"] },
        "one_liner": { "type": "string" },
        "rationale": { "type": "string" },
        "trade_offs": { "type": "array", "items": { "type": "string" } },
        "minimal_patch": {
          "anyOf": [
            { "$ref": "#/$defs/minimalPatch" },
            { "type": "null" }
          ]
        },
        "investigation_hints": { "type": "array", "items": { "type": "string" } },
        "fix_options": { "type": "array", "items": { "$ref": "#/$defs/fixOption" } },
        "evidence": { "type": "object" },
        "distribution": { "type": "string" }
      }
    }
  }
}
